# OpenAI GPT Image
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_FORMAT=png

# Local ComfyUI / TripoSG / Hunyuan3D-Paint
